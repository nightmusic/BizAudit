{
  "name": "bizaudit",
  "version": "1.0.0",
  "description": "A domain-driven CLI prototype that combines static analysis defects with business context to produce business impact evaluations.",
  "main": "dist/presentation/cli.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "ts-node src/presentation/cli.ts",
    "help": "ts-node src/presentation/cli.ts --help",
    "test": "npm run typecheck"
  },
  "keywords": [
    "bizaudit",
    "cli",
    "code-review",
    "static-analysis",
    "domain-driven-design",
    "business-rules",
    "typescript",
    "eslint"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/nightmusic/BizAudit.git"
  },
  "bugs": {
    "url": "https://github.com/nightmusic/BizAudit/issues"
  },
  "homepage": "https://github.com/nightmusic/BizAudit#readme",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  }
}
